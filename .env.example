# AsteriaStar environment configuration — copy to `.env.local` and fill in.
# Every value is optional; sensible defaults keep dev and CI green without it.

# Absolute site origin (no trailing slash). Defaults to https://asteriastar.com.
NEXT_PUBLIC_SITE_URL=https://asteriastar.com

# IndexNow key. The verification file public/<INDEXNOW_KEY>.txt is materialised
# from this value by the prebuild step (scripts/generate-indexnow-key.ts) and is
# the only place the literal key lives. In production set this as a secret/env
# var; the IndexNow submit job reads the same variable.
INDEXNOW_KEY=c292fa58c74f45f9ad982e152b4f7c1c

# WebmasterID analytics (optional overrides — the defaults are baked into the
# tracker component, so leaving these unset uses the production identifiers).
# NEXT_PUBLIC_WEBMASTERID_SITE_ID=wm_knpkrkxcizuzoa0s
# NEXT_PUBLIC_WEBMASTERID_ENDPOINT=https://webmasterid-ingest-api.vercel.app/api/events
